# Supabase project credentials (Project Settings -> API in the Supabase dashboard).
# These are exposed to the browser (Vite "VITE_" prefix), so use the public
# anon key only — never the service_role key. Access control is enforced via
# Row Level Security policies (see supabase/schema.sql).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
